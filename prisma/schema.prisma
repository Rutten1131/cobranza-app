generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  user
}

enum RecordStatus {
  pending
  paid
  overdue
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  role          Role      @default(user)
  businessName  String?   @map("business_name")
  businessType  String?   @map("business_type")
  whatsappSender String?  @map("whatsapp_sender")
  evolutionInstance String? @map("evolution_instance")
  evolutionToken   String? @map("evolution_token")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  defaultReminderDays Int  @default(5) @map("default_reminder_days")
  defaultReminderTime String @default("08:00") @map("default_reminder_time")
  defaultReminderMessage String? @map("default_reminder_message")
  hasCobranzas  Boolean   @default(true) @map("has_cobranzas")
  hasHabitaciones Boolean   @default(false) @map("has_habitaciones")
  hasBarberia   Boolean   @default(false) @map("has_barberia")
  barberRequiredCuts Int     @default(5) @map("barber_required_cuts")
  barberGoogleMapsUrl String? @map("barber_google_maps_url")

  clients Client[]
  records Record[]
  inventoryItems InventoryItem[]
  hotelRooms HotelRoom[]
  hotelReservations HotelReservation[]
  hotelRoomTypes HotelRoomType[]
  barberStaff BarberStaff[]
  barberCustomers BarberCustomer[]
  barberCuts BarberCut[]
  barberCodes BarberCode[]

  @@map("users")
}

model Client {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  phone     String
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  records Record[]

  @@map("clients")
}

model Record {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  clientId     String       @map("client_id")
  description  String
  amount       Decimal?     @db.Decimal(10,2)
  dueDate      DateTime     @map("due_date")
  issueDate    DateTime     @default(now()) @map("issue_date")
  status       RecordStatus @default(pending)
  reminderSent Boolean      @default(false) @map("reminder_sent")
  customMessage String?     @db.Text @map("custom_message")
  inventoryItemId String?   @map("inventory_item_id")
  createdAt    DateTime     @default(now()) @map("created_at")

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  client            Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  inventoryItem     InventoryItem?    @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  logs             MessageLog[]
  reminderSchedule ReminderSchedule[]

  @@map("records")
}

model InventoryItem {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  name           String
  description    String?  @db.Text
  sku            String?
  price          Decimal? @db.Decimal(10,2)
  stock          Int      @default(1)
  availableStock Int      @default(1) @map("available_stock")
  customFields   Json?    @map("custom_fields")
  createdAt      DateTime @default(now()) @map("created_at")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  records        Record[]

  @@map("inventory_items")
}

model ReminderSchedule {
  id              String   @id @default(uuid())
  recordId        String   @map("record_id")
  scheduledDate   DateTime @map("scheduled_date") // Quitamos @db.Date para almacenar la hora completa
  sentAt          DateTime? @map("sent_at")
  status          String   @default("pending") // pending, sent, failed
  reminderNumber  Int      @map("reminder_number") // 1, 2, 3, 4...
  createdAt       DateTime @default(now()) @map("created_at")

  record Record @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@map("reminder_schedules")
}

model MessageLog {
  id          String   @id @default(uuid())
  recordId    String   @map("record_id")
  sentAt      DateTime @default(now()) @map("sent_at")
  messageText String?  @map("message_text")
  status      String

  record Record @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@map("message_logs")
}

model HotelRoom {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  number    String
  type      String
  price     Float
  status    String   @default("libre") // libre, ocupada, sucia
  createdAt DateTime @default(now()) @map("created_at")

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservations HotelReservation[]

  @@unique([userId, number])
  @@map("hotel_rooms")
}

model HotelReservation {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  roomId       String   @map("room_id")
  guestName    String   @map("guest_name")
  guestEmail   String?  @map("guest_email")
  guestPhone   String   @map("guest_phone")
  amount       Float
  status       String   @default("pending") // pending, paid, cancelled
  checkInDate  DateTime @map("check_in_date")
  checkOutDate DateTime @map("check_out_date")
  adults       Int      @default(2)
  kids         Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  room HotelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("hotel_reservations")
}

model HotelRoomType {
  id     String @id @default(uuid())
  userId String @map("user_id")
  name   String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@map("hotel_room_types")
}

model ValidationLead {
  id              String   @id @default(uuid())
  name            String
  businessName    String   @map("business_name")
  whatsapp        String
  email           String
  city            String
  answers         Json     // Respuestas completas en formato JSON
  score           Int      // Índice de automatización/riesgo calculado
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("validation_leads")
}

model BarberStaff {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cuts      BarberCut[]

  @@map("barber_staff")
}

model BarberCustomer {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  whatsapp    String
  name        String?
  cutsCount   Int      @default(0) @map("cuts_count")
  lastVisit   DateTime @default(now()) @map("last_visit")
  hasReviewed Boolean  @default(false) @map("has_reviewed")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cuts        BarberCut[]

  @@unique([userId, whatsapp])
  @@map("barber_customers")
}

model BarberCut {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  customerId     String   @map("customer_id")
  staffId        String?  @map("staff_id")
  rating         Int?
  codeUsed       String   @map("code_used")
  createdAt      DateTime @default(now()) @map("created_at")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer       BarberCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  staff          BarberStaff?   @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@map("barber_cuts")
}

model BarberCode {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  code      String
  isUsed    Boolean  @default(false) @map("is_used")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, code])
  @@map("barber_codes")
}